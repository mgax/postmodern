keybind = super+c=copy_to_clipboard
keybind = shift+enter=text:\x1b[13;2u
keybind = super+s=text:\x1bs
keybind = super+w=text:\x1bw
keybind = super+slash=text:\x1b/
keybind = super+alt+t=text:\x1bt
keybind = super+alt+shift+left_bracket=text:\x1b{
keybind = super+alt+shift+right_bracket=text:\x1b}

window-inherit-working-directory = false
window-inherit-font-size = false
window-width = 100
window-height = 30
tab-inherit-working-directory = true
term=xterm-256color
notify-on-command-finish = unfocused
notify-on-command-finish-after = 5s
